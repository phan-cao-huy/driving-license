<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".LicenseSelectionActivity">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/black" />

        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chọn hạng bằng lái"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/divider1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Vui lòng chọn hạng bằng bạn muốn ôn tập:"
                android:textColor="#757575"
                android:textSize="14sp" />

            <!-- Nhóm bằng XE MÁY -->
            <LinearLayout
                android:id="@+id/layoutMotorbikeLicenses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnA1"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical|start"
                    android:paddingStart="24dp"
                    android:text="Hạng A1"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_chevron_right"
                    app:iconGravity="end"
                    app:iconTint="#BDBDBD"
                    app:strokeColor="#DDDDDD" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnA2"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical|start"
                    android:paddingStart="24dp"
                    android:text="Hạng A2"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_chevron_right"
                    app:iconGravity="end"
                    app:iconTint="#BDBDBD"
                    app:strokeColor="#DDDDDD" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnA3"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical|start"
                    android:paddingStart="24dp"
                    android:text="Hạng A3"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_chevron_right"
                    app:iconGravity="end"
                    app:iconTint="#BDBDBD"
                    app:strokeColor="#DDDDDD" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnA4"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical|start"
                    android:paddingStart="24dp"
                    android:text="Hạng A4"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_chevron_right"
                    app:iconGravity="end"
                    app:iconTint="#BDBDBD"
                    app:strokeColor="#DDDDDD" />
            </LinearLayout>

            <!-- Nhóm bằng Ô TÔ -->
            <LinearLayout
                android:id="@+id/layoutCarLicenses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnB1"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical|start"
                    android:paddingStart="24dp"
                    android:text="Hạng B1"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_chevron_right"
                    app:iconGravity="end"
                    app:iconTint="#BDBDBD"
                    app:strokeColor="#DDDDDD" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnB2"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical|start"
                    android:paddingStart="24dp"
                    android:text="Hạng B2"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_chevron_right"
                    app:iconGravity="end"
                    app:iconTint="#BDBDBD"
                    app:strokeColor="#DDDDDD" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnC"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical|start"
                    android:paddingStart="24dp"
                    android:text="Hạng C"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_chevron_right"
                    app:iconGravity="end"
                    app:iconTint="#BDBDBD"
                    app:strokeColor="#DDDDDD" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnD"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical|start"
                    android:paddingStart="24dp"
                    android:text="Hạng D"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_chevron_right"
                    app:iconGravity="end"
                    app:iconTint="#BDBDBD"
                    app:strokeColor="#DDDDDD" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>